# AVDB-SERVER 环境变量示例
# 复制为 .env 并按需修改

# --- 鉴权 ---
AUTH_DISABLED=true
SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- 数据库（空=默认 SQLite data/javdb.db；PostgreSQL 示例见下）---
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://user:pass@postgres:5432/avdb

# --- 爬虫 ---
JAVDB_URL=https://javdb.com
# 代理（Playwright/httpx 访问 javdb 用）
HTTP_PROXY=
HTTPS_PROXY=

# --- 调试 ---
DEBUG=false
