# AVDB-SERVER 环境变量示例
# 复制为 .env 并按需修改

# --- 鉴权 ---
# 生产环境必须设为 false（留空 SECRET_KEY/ADMIN_PASSWORD 时首次启动自动生成随机值）
AUTH_DISABLED=false
SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- 数据库（空=默认 SQLite data/javdb.db；PostgreSQL 示例见下）---
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://user:pass@postgres:5432/avdb

# --- 爬虫 ---
JAVDB_URL=https://javdb.com
SCRAPER_PYTHON=
# 代理（Playwright/httpx 访问 javdb 用）
HTTP_PROXY=
HTTPS_PROXY=

# --- 目录 ---
DATA_DIR=data
IMAGES_DIR=data/images

# --- 调试 ---
DEBUG=false
